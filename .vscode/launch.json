{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug NestJS",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nest", "start", "--debug", "--watch"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true,
      "skipFiles": ["node_modules/**"],
      "console": "integratedTerminal"
    }
  ]
}
